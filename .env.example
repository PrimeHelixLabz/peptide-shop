# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional: For admin operations (server-side only)
# This key bypasses Row Level Security policies
SUPABASE_SECRET_KEY=your_supabase_secret_key

# API Configuration (optional - leave empty to use relative URLs)
NEXT_PUBLIC_API_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# E2E test admin credentials
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Resend (transactional email)
RESEND_API_KEY=

# Newsletter (required in production)
# Salt used to hash subscriber IPs. Generate with: openssl rand -hex 32
NEWSLETTER_IP_SALT=
# HMAC key for one-click unsubscribe links. Generate with: openssl rand -hex 32
NEWSLETTER_UNSUBSCRIBE_SECRET=

# Link Money (Pay by Bank) - set to "true" to show Pay by Bank button (dev only)
NEXT_PUBLIC_ENABLE_LINK_MONEY=false

LINK_MONEY_CLIENT_ID=
LINK_MONEY_CLIENT_SECRET=
LINK_MONEY_ENV=sandbox
LINK_MONEY_REDIRECT_URL=http://localhost:3000/payments/link-money/callback
LINK_MONEY_WEBHOOK_SECRET=

# CentryOS payment gateway
# Set to "sandbox" or "production". Default base URLs are derived from this.
CENTRYOS_ENV=sandbox
# Override defaults only when CentryOS gives you a different host:
# CENTRYOS_ACCOUNT_URL=https://account-staging-api.centryos.xyz
# CENTRYOS_LIQUIDITY_URL=https://liquidity-staging-api.centryos.xyz
CENTRYOS_API_CLIENT_ID=
CENTRYOS_API_CLIENT_SECRET=
CENTRYOS_WEBHOOK_SECRET=
CENTRYOS_DEFAULT_CURRENCY=USD
# Public origin used by CentryOS for the website + webhook callback URL.
APP_PUBLIC_URL=http://localhost:3000

# Sentry (error monitoring)
# Without a DSN, Sentry.init() is skipped everywhere and NO events are sent —
# the SENTRY_AUTH_TOKEN below only covers build-time source-map upload.
# Find the DSN in Sentry: Settings -> Projects -> javascript-nextjs -> Client Keys (DSN).
# The DSN is not a secret (it ships in the client bundle); set the public one.
NEXT_PUBLIC_SENTRY_DSN=
# Optional server-only override. If unset, the server falls back to NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=
# Build-time only: used by the Sentry build plugin to upload source maps. Not a runtime DSN.
SENTRY_AUTH_TOKEN=
