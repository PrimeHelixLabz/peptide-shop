# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional: For admin operations (server-side only)
# This key bypasses Row Level Security policies
SUPABASE_SECRET_KEY=your_supabase_secret_key

# API Configuration (optional - leave empty to use relative URLs)
NEXT_PUBLIC_API_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Link Money (Pay by Bank)
LINK_MONEY_CLIENT_ID=
LINK_MONEY_CLIENT_SECRET=
LINK_MONEY_ENV=sandbox
LINK_MONEY_REDIRECT_URL=http://localhost:3000/payments/link-money/callback